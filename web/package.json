{
  "name": "tfoodies-web",
  "private": true,
  "version": "0.0.0",
  "description": "TFoodies frontend monorepo — Nuxt 3 store (SEO/SSR) + Vue 3 admin SPA + shared design tokens",
  "workspaces": [
    "packages/*",
    "store",
    "admin"
  ],
  "scripts": {
    "dev:store": "npm --workspace store run dev",
    "dev:admin": "npm --workspace admin run dev",
    "build:store": "npm --workspace store run build",
    "build:admin": "npm --workspace admin run build"
  },
  "dependencies": {
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-youtube": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/vue-3": "^3.26.0"
  }
}
