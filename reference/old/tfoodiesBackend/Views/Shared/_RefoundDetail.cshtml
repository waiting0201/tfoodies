@model IEnumerable<Returns>

<fieldset class="refounddetail">

    <div class="table-responsive">
        <table id="dt_basic" class="table table-bordered has-tickbox">
            <thead>
                <tr>
                    <th></th>
                    <th class="text-left">退貨單號</th>
                    <th width="8%" class="text-center">退貨日期</th>
                    <th width="6%" class="text-right">應退金額</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Returns entity in Model)
                {
                    <tr>
                        <td>
                            <label>
                                <input type="radio" name="returnid" value="@entity.returnid" />
                            </label>
                        </td>
                        <td class="text-left">@entity.returncode</td>
                        <td class="text-center">@entity.returndate.ToString("yyyy-MM-dd")</td>
                        <td class="text-right"><b>@entity.Returndetails.Sum(a => a.price)</b></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</fieldset>