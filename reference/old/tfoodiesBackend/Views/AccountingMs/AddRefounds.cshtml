@model Refounds

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>新增退款</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" action="@Url.Action("AddRefounds", "AccountingMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                <fieldset>

                                    <legend>退款資料</legend>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="memberid">會員</label>
                                        <div class="col-lg-2">
                                            @Html.DropDownListFor(model => model.memberid, null, "--請選擇會員--", new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇會員" } })
                                            @Html.ValidationMessageFor(model => model.memberid)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="refounddate">退款日期</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.refounddate, new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇退款日期" } })
                                            @Html.ValidationMessageFor(model => model.refounddate)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="amount">金額</label>
                                        <div class="col-lg-1">
                                            @Html.TextBoxFor(model => model.amount, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入金額" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                            @Html.ValidationMessageFor(model => model.amount)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="note">備註</label>
                                        <div class="col-lg-3">
                                            @Html.TextAreaFor(model => model.note, 3, 50, new Dictionary<string, object>() { { "class", "form-control" } })
                                            @Html.ValidationMessageFor(model => model.note)
                                        </div>
                                    </div>

                                </fieldset>

                                <fieldset class="refounddetail"></fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Refounds", "AccountingMs")">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {
    <script>

        $(function () {

            $(document).on('change', '#memberid', function () {
                var obj = $(this);

                if (obj.val() != null && obj.val() != '')
                {
                    $.post("@Url.Action("GetRefoundDetail", "Ajax")", { memberid: obj.val() }, function(result) {
                        $(".refounddetail").replaceWith(result);
                    });
                }
            });

        });

    </script>
}