@model Invoices
@{
    var invoicelist = (IEnumerable<Invoicedetails>)ViewBag.InvoiceDetail;
}

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>編輯請款</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" action="@Url.Action("EditInvoices", "AccountingMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                @Html.HiddenFor(model => model.invoiceid)

                                <fieldset>

                                    <legend>請款資料</legend>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="memberid">會員</label>
                                        <div class="col-lg-2">
                                            @Html.DisplayFor(model => model.Members.name)
                                            @Html.HiddenFor(model => model.memberid)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="requestdate">請款日期</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.requestdate, "{0:yyyy-MM-dd}", new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇請款日期" } })
                                            @Html.ValidationMessageFor(model => model.requestdate)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="note">備註</label>
                                        <div class="col-lg-3">
                                            @Html.TextAreaFor(model => model.note, 3, 50, new Dictionary<string, object>() { { "class", "form-control" } })
                                            @Html.ValidationMessageFor(model => model.note)
                                        </div>
                                    </div>

                                </fieldset>

                                <fieldset>

                                    <div class="table-responsive">
                                        <table id="dt_basic" class="table table-bordered has-tickbox">
                                            <thead>
                                                <tr>
                                                    <th></th>
                                                    <th class="text-left">訂單單號</th>
                                                    <th width="8%" class="text-center">訂單日期</th>
                                                    <th width="12%" class="text-center">發票號碼</th>
                                                    <th width="6%" class="text-right">金額</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (Invoicedetails entity in invoicelist)
                                                {
                                                    <tr>
                                                        <td>
                                                            <label>
                                                                <input type="checkbox" name="orderid" value="@entity.orderid" disabled @(Model.Invoicedetails.Where(a => a.orderid == entity.orderid) != null ? "checked" : "") />
                                                            </label>
                                                        </td>
                                                        <td class="text-left">@entity.Orders.ordercode</td>
                                                        <td class="text-center">@entity.Orders.orderdate.ToString("yyyy-MM-dd")</td>
                                                        <td class="text-center">@entity.Orders.invoicecode</td>
                                                        <td class="text-right"><b>@entity.price</b></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>

                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Invoices", "AccountingMs")">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {

}