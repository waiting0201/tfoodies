@model Products

@{
    var tagdatas = (IEnumerable<Tags>)ViewBag.Tags;
}

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>新增產品</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" enctype="multipart/form-data" action="@Url.Action("AddProducts", "ProductMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                    <fieldset>

                                        <legend>產品資料</legend>
                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="producttypeid">分類</label>
                                            <section class="col-lg-2">
                                                @Html.DropDownListFor(model => model.producttypeid, null, "--請選擇分類--", new Dictionary<string, object>() { { "class", "form-control" }, { "style", "width:100%" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇分類" } })
                                                @Html.ValidationMessageFor(model => model.producttypeid)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="brandid">品牌</label>
                                            <section class="col-lg-2">
                                                @Html.DropDownListFor(model => model.brandid, null, "--請選擇品牌--", new Dictionary<string, object>() { { "class", "form-control" }, { "style", "width:100%" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇品牌" } })
                                                @Html.ValidationMessageFor(model => model.brandid)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="productnum">產品編號</label>
                                            <section class="col-lg-2">
                                                @Html.TextBoxFor(model => model.productnum, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入產品編號" }, { "data-bv-remote", "true" }, { "data-bv-remote-url", Url.Action("Checkproductnum", "Ajax") }, { "data-bv-remote-message", "產品編號重複" }, { "data-bv-remote-type", "GET" } })
                                                @Html.ValidationMessageFor(model => model.productnum)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="isset">組套禮盒</label>
                                            <div class="col-lg-2">
                                                <div class="checkbox">
                                                    <label>
                                                        @Html.CheckBoxFor(model => model.isset)
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="form-group productids hidden">
                                            <label class="col-lg-2 control-label">套組內容</label>
                                            <section class="col-lg-7">
                                                <div class="row">

                                                    <div class="form-inline">
                                                        <div class="col-sm-12 text-right">
                                                            <a class="btn btn-success btn-labeled" href="javascript:;" id="addproduct"> <span class="btn-label"><i class="fa fa-plus"></i></span>新增產品 </a>
                                                        </div>
                                                    </div>

                                                </div>

                                                <br>

                                                <div class="table-responsive">

                                                    <table id="dt_basic" class="table table-bordered producttable">
                                                        <thead>
                                                            <tr>
                                                                <th width="18%">產品編號</th>
                                                                <th>產品名稱</th>
                                                                <th class="text-center" width="10%">數量</th>
                                                                <th class="text-center" width="8%">刪除</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @*<tr>
                                <td><input type="text" name="pn" class="form-control productnum" /><input type="hidden" name="setproducts[0].productid" /><input type="hidden" name="setproducts[0].oproductid" value="00000000-0000-0000-0000-000000000000" /></td>
                                <td></td>
                                <td><input type="text" name="setproducts[0].qty" class="form-control text-center" /></td>
                                <td class="text-center"><a href="javascript:;" class="btn btn-danger btn-xs del"><i class="fa fa-trash-o"></i></a></td>
                            </tr>*@
                                                        </tbody>
                                                    </table>

                                                </div>
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="title">標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.title, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入標題" }, { "data-bv-remote", "true" }, { "data-bv-remote-url", Url.Action("Checkproductname", "Ajax") }, { "data-bv-remote-message", "標題重複" }, { "data-bv-remote-type", "GET" } })
                                                @Html.ValidationMessageFor(model => model.title)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="entitle">英文標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.entitle, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.entitle)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="intro">簡介</label>
                                            <section class="col-lg-5">
                                                @Html.TextAreaFor(model => model.intro, 3, 40, new Dictionary<string, object>() { { "class", "form-control" } })
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="fixprice">定價</label>
                                            <section class="col-lg-1">
                                                @Html.TextBoxFor(model => model.fixprice, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入定價" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                                @Html.ValidationMessageFor(model => model.fixprice)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="price">售價</label>
                                            <section class="col-lg-1">
                                                @Html.TextBoxFor(model => model.price, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入售價" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                                @Html.ValidationMessageFor(model => model.price)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="capacity">容量</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.capacity, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.capacity)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="photo">代表圖</label>
                                            <div class="col-lg-2">
                                                <input type="file" class="btn btn-default" id="photo" name="photo"
                                                       data-bv-notempty="true"
                                                       data-bv-notempty-message="請選擇代表圖"
                                                       data-bv-file="true"
                                                       data-bv-file-extension="jpeg,jpg,png,gif"
                                                       data-bv-file-type="image/jpeg,image/png,image/gif"
                                                       data-bv-file-message="代表圖格式不符">
                                                <p class="note">
                                                    建議尺寸 : 317 x 464
                                                </p>
                                                @Html.ValidationMessageFor(model => model.photo)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="added">上架數</label>
                                            <div class="col-lg-1">
                                                @Html.TextBoxFor(model => model.added, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入上架數" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                                @Html.ValidationMessageFor(model => model.added)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="isdisabled">下架</label>
                                            <div class="col-lg-2">
                                                <div class="checkbox">
                                                    <label>
                                                        @Html.CheckBoxFor(model => model.isdisabled)
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="memo">內容</label>
                                            <section class="col-lg-10">
                                                @Html.TextAreaFor(model => model.memo, 3, 60, new Dictionary<string, object>() { { "class", "form-control summernote" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入內容" } })
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label">標籤</label>
                                            <section class="col-lg-10">
                                                @foreach (Tags tag in tagdatas)
            {
                                    <div class="checkbox-inline">
                                        <label>
                                            <input type="checkbox" name="tagids" value="@tag.tagid">
                                            <span>@tag.title</span>
                                        </label>
                                    </div>
}
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="weight">重量</label>
                                            <div class="col-lg-1">
                                                @Html.TextBoxFor(model => model.weight, new Dictionary<string, object>() { { "class", "form-control" }, { "pattern", "^[0-9]+(.[0-9]{0,3})?$" }, { "data-bv-regexp-message", "格式錯誤，小數點後三位" } }) <span>KG</span>
                                                @Html.ValidationMessageFor(model => model.weight)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="unit">庫存大單位</label>
                                            <div class="col-lg-1">
                                                @Html.TextBoxFor(model => model.unit, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.unit)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="conversion">庫存單位換算</label>
                                            <div class="col-lg-1">
                                                @Html.TextBoxFor(model => model.conversion, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                                @Html.ValidationMessageFor(model => model.conversion)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="isgroupbuy">團購表單</label>
                                            <div class="col-lg-2">
                                                <div class="checkbox">
                                                    <label>
                                                        @Html.CheckBoxFor(model => model.isgroupbuy)
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="shortener">短網址</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.shortener, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.shortener)
                                            </section>
                                        </div>

                                    </fieldset>

                                <fieldset>

                                    <legend>SEO資料</legend>
                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="keyword">關鍵字</label>
                                        <section class="col-lg-3">
                                            @Html.TextBoxFor(model => model.keyword, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入關鍵字" } })
                                            <p class="note">
                                                列三個關鍵字即可，不重複同樣的關鍵詞，需與文章內容相符
                                            </p>
                                            @Html.ValidationMessageFor(model => model.keyword)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="description">描述</label>
                                        <section class="col-lg-3">
                                            @Html.TextAreaFor(model => model.description, 3, 60, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入描述" } })
                                            <p class="note">
                                                字數控制在150字內，為文章內容大意，不得照摳文章內容來當敘述，盡量把關鍵字寫在敘述裡，不可以有引號
                                            </p>
                                            @Html.ValidationMessageFor(model => model.description)
                                        </section>
                                    </div>

                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Products", "ProductMs", new { p = ViewBag.pageNumber })">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>

                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {
<script>
    function recountRow(obj) {
        var countRow = 0;
        obj.find('tr').each(function () {
            $(this).find("input,textarea").each(function () {
                $(this).attr("name", $(this).attr("name").replace(/\[(\d+)\]/g, "[" + countRow + "]"));
            });
            countRow++;
        });
    }

    $(function () {
        $("#isset").on("click", function () {
            var obj = $(this);
            var tobj = $(".productids");

            if (obj.is(':checked')) {
                tobj.removeClass("hidden");
            }else {
                tobj.addClass("hidden");
            }
        });

        $("#addproduct").click(function () {
            var obj = $('.producttable tbody');
            var countRow = obj.find('tr').length;

            var row = '<tr>';
            row += '<td><input type="text" name="pn" class="form-control productnum" /><input type="hidden" name="setproducts[' + countRow + '].productid" value="" /><input type="hidden" name="setproducts[' + countRow + '].oproductid" value="00000000-0000-0000-0000-000000000000" /></td>';
            row += '<td></td>';
            row += '<td>';
            row += '<input type="text" name="setproducts[' + countRow + '].qty" class="form-control text-center" />';
            row += '</td>';
            row += '<td class="text-center"><a href="javascript:;" class="btn btn-danger btn-xs del"><i class="fa fa-trash-o"></i></a></td>';
            row += '</tr>';

            obj.append(row);
        });

        $('.table').on('click', '.del', function () {
            var obj = $(this).parent().parent().parent();
            var countRow = obj.find('tr').length;
            if (countRow > 0) {
                var trobj = $(this).parent().parent();
                var tbobj = trobj.parent();
                trobj.remove();
                recountRow(tbobj);
            }
        });

        $('.producttable').on('blur', '.productnum', function (e) {
            var obj = $(this);
            var procode = obj.val();
            var trobj = obj.parents("tr");
            var tbobj = obj.parents("tbody");
            var isavalible = true;

            //***************判斷產品是否重複**************//
            //trobj.addClass("currentrow");
            //tbobj.find("tr").each(function () {
            //    if (!$(this).hasClass("currentrow")) {
            //        var v = $(this).find("input.productnum").val();
            //        if (v == procode) {
            //            isavalible = false;
            //            return false;
            //        }
            //    }
            //});
            //trobj.removeClass("currentrow");
            //*********************************************//

            if (isavalible && procode != "") {
                $.post('@Url.Action("GetProductbyProductnum", "Ajax")', {
                    productnum: procode
                }, function (res) {
                    if (res.code == "200") {
                        trobj.find("td:eq(1)").html(res.title + " " + res.capacity);
                        trobj.find("input").each(function () {
                            if ($(this).attr("name").search(/(productid)/) == 15) $(this).val(res.productid);
                            if ($(this).attr("name").search(/(qty)/) != -1) $(this).val(1);
                        });
                    } else {
                        alert("查無此產品!");
                        return;
                    }
                });
            } else {
                alert("產品不可以重複加入!");
                return;
            }
        });
    });
</script>
}