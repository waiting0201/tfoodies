@model Brands

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>新增品牌</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" enctype="multipart/form-data" action="@Url.Action("AddBrands", "ProductMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                    <fieldset>

                                        <legend>品牌資料</legend>
                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="title">標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.title, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入標題" } })
                                                @Html.ValidationMessageFor(model => model.title)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="subtitle">副標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.subtitle, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入副標題" } })
                                                @Html.ValidationMessageFor(model => model.subtitle)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="logo">Logo</label>
                                            <div class="col-lg-2">
                                                <input type="file" class="btn btn-default" id="logo" name="logo"
                                                       data-bv-notempty="true"
                                                       data-bv-notempty-message="請選擇Logo"
                                                       data-bv-file="true"
                                                       data-bv-file-extension="jpeg,jpg,png,gif"
                                                       data-bv-file-type="image/jpeg,image/png,image/gif"
                                                       data-bv-file-message="Logo格式不符">
                                                <p class="note">
                                                    建議尺寸 : 118 x 94
                                                </p>
                                                @Html.ValidationMessageFor(model => model.logo)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="banner">Banner</label>
                                            <div class="col-lg-2">
                                                <input type="file" class="btn btn-default" id="banner" name="banner"
                                                       data-bv-notempty="true"
                                                       data-bv-notempty-message="請選擇Banner"
                                                       data-bv-file="true"
                                                       data-bv-file-extension="jpeg,jpg,png,gif"
                                                       data-bv-file-type="image/jpeg,image/png,image/gif"
                                                       data-bv-file-message="Banner格式不符">
                                                <p class="note">
                                                    建議尺寸 : 1440 x 455
                                                </p>
                                                @Html.ValidationMessageFor(model => model.banner)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="patternentitle">Pattern英文標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.patternentitle, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "Pattern英文標題" } })
                                                @Html.ValidationMessageFor(model => model.patternentitle)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="patternchtitle">Pattern中文標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.patternchtitle, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "Pattern中文標題" } })
                                                @Html.ValidationMessageFor(model => model.patternchtitle)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="parttnervideo">Pattern影片</label>
                                            <section class="col-lg-4">
                                                @Html.TextBoxFor(model => model.parttnervideo, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.parttnervideo)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="patternmemo">Pattern簡介</label>
                                            <section class="col-lg-3">
                                                @Html.TextAreaFor(model => model.patternmemo, 3, 50, new Dictionary<string, object>() { { "class", "form-control summernote" } })
                                                @Html.ValidationMessageFor(model => model.patternmemo)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="patternclass">Pattern背景</label>
                                            <div class="col-lg-2">
                                                <input type="file" class="btn btn-default" id="patternclass" name="patternclass"
                                                       data-bv-notempty="true"
                                                       data-bv-notempty-message="請選擇Pattern背景"
                                                       data-bv-file="true"
                                                       data-bv-file-extension="jpeg,jpg,png,gif"
                                                       data-bv-file-type="image/jpeg,image/png,image/gif"
                                                       data-bv-file-message="Pattern背景格式不符">
                                                <p class="note">
                                                    建議尺寸 : 1440 x 220
                                                </p>
                                                @Html.ValidationMessageFor(model => model.patternclass)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="ilogo">副Logo</label>
                                            <div class="col-lg-2">
                                                <input type="file" class="btn btn-default" id="ilogo" name="ilogo"
                                                       data-bv-file="true"
                                                       data-bv-file-extension="jpeg,jpg,png,gif"
                                                       data-bv-file-type="image/jpeg,image/png,image/gif"
                                                       data-bv-file-message="副Logo格式不符">
                                                <p class="note">
                                                    建議尺寸 : 92 x 81
                                                </p>
                                                @Html.ValidationMessageFor(model => model.ilogo)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="slogan">Slogan</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.slogan, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入Slogan" } })
                                                @Html.ValidationMessageFor(model => model.slogan)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="intro">簡介</label>
                                            <section class="col-lg-3">
                                                @Html.TextAreaFor(model => model.intro, 3, 60, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.intro)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="storybgclass">背景</label>
                                            <div class="col-lg-2">
                                                <input type="file" class="btn btn-default" id="storybgclass" name="storybgclass"
                                                       data-bv-notempty="true"
                                                       data-bv-notempty-message="請選擇背景"
                                                       data-bv-file="true"
                                                       data-bv-file-extension="jpeg,jpg,png,gif"
                                                       data-bv-file-type="image/jpeg,image/png,image/gif"
                                                       data-bv-file-message="背景格式不符">
                                                <p class="note">
                                                    建議尺寸 : 1440 x 867
                                                </p>
                                                @Html.ValidationMessageFor(model => model.storybgclass)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="storyentitle">故事英文標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.storyentitle, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "故事英文標題" } })
                                                @Html.ValidationMessageFor(model => model.storyentitle)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="storychtitle">故事中文標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.storychtitle, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "故事中文標題" } })
                                                @Html.ValidationMessageFor(model => model.storychtitle)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="storymemo">故事簡介</label>
                                            <section class="col-lg-3">
                                                @Html.TextAreaFor(model => model.storymemo, 3, 60, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.storymemo)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="peopletitle">人物標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.peopletitle, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "人物標題" } })
                                                @Html.ValidationMessageFor(model => model.peopletitle)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="peopleslogan">人物Slogan</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.peopleslogan, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "人物Slogan" } })
                                                @Html.ValidationMessageFor(model => model.peopleslogan)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="peoplememo">人物簡介</label>
                                            <section class="col-lg-3">
                                                @Html.TextAreaFor(model => model.peoplememo, 3, 60, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.peoplememo)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="peoplephoto">人物圖</label>
                                            <div class="col-lg-2">
                                                <input type="file" class="btn btn-default" id="peoplephoto" name="peoplephoto"
                                                       data-bv-notempty="true"
                                                       data-bv-notempty-message="請選擇人物圖"
                                                       data-bv-file="true"
                                                       data-bv-file-extension="jpeg,jpg,png,gif"
                                                       data-bv-file-type="image/jpeg,image/png,image/gif"
                                                       data-bv-file-message="人物圖格式不符">
                                                <p class="note">
                                                    建議尺寸 : 1440 x 654
                                                </p>
                                                @Html.ValidationMessageFor(model => model.peoplephoto)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="isdisplay">顯示</label>
                                            <div class="col-lg-3">
                                                <label class="radio radio-inline">
                                                    @Html.RadioButtonFor(model => model.isdisplay, 1, new { @checked = "checked" })
                                                    是
                                                </label>
                                                <label class="radio radio-inline">
                                                    @Html.RadioButtonFor(model => model.isdisplay, 2)
                                                    否
                                                </label>
                                            </div>
                                        </div>

                                    </fieldset>

                                <fieldset>

                                    <legend>SEO資料</legend>
                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="keyword">關鍵字</label>
                                        <section class="col-lg-3">
                                            @Html.TextBoxFor(model => model.keyword, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入關鍵字" } })
                                            <p class="note">
                                                列三個關鍵字即可，不重複同樣的關鍵詞，需與文章內容相符
                                            </p>
                                            @Html.ValidationMessageFor(model => model.keyword)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="description">描述</label>
                                        <section class="col-lg-3">
                                            @Html.TextAreaFor(model => model.description, 3, 60, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入描述" } })
                                            <p class="note">
                                                字數控制在150字內，為文章內容大意，不得照摳文章內容來當敘述，盡量把關鍵字寫在敘述裡，不可以有引號
                                            </p>
                                            @Html.ValidationMessageFor(model => model.description)
                                        </section>
                                    </div>

                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Brands", "ProductMs", new { p = ViewBag.pageNumber })">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {

}