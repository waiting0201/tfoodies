@model Banners

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>新增首頁輪播</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" enctype="multipart/form-data" action="@Url.Action("AddBanners", "HomeMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                <fieldset>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="photo">Banner</label>
                                        <div class="col-lg-2">
                                            <input type="file" class="btn btn-default" id="photo" name="photo"
                                                   data-bv-notempty="true"
                                                   data-bv-notempty-message="請選擇圖"
                                                   data-bv-file="true"
                                                   data-bv-file-extension="jpeg,jpg,png,gif"
                                                   data-bv-file-type="image/jpeg,image/png,image/gif"
                                                   data-bv-file-message="圖格式不符">
                                            <p class="note">
                                                建議尺寸 : 1920 x 770
                                            </p>
                                            @Html.ValidationMessageFor(model => model.photo)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="style">樣式</label>
                                        <div class="col-lg-3">
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.style, 1, new { @checked = "checked" })
                                                僅連結
                                            </label>
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.style, 2)
                                                內容置中
                                            </label>
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.style, 3)
                                                內容靠左
                                            </label>
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.style, 4)
                                                影片
                                            </label>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="title">標題</label>
                                        <section class="col-lg-3">
                                            @Html.TextBoxFor(model => model.title, new Dictionary<string, object>() { { "class", "form-control" } })
                                            @Html.ValidationMessageFor(model => model.title)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="subtitle">副標題</label>
                                        <section class="col-lg-3">
                                            @Html.TextBoxFor(model => model.subtitle, new Dictionary<string, object>() { { "class", "form-control" } })
                                            @Html.ValidationMessageFor(model => model.subtitle)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="url">連結</label>
                                        <section class="col-lg-5">
                                            @Html.TextBoxFor(model => model.url, new Dictionary<string, object>() { { "class", "form-control" }, { "placeholder", "http://" } })
                                            @Html.ValidationMessageFor(model => model.url)
                                        </section>
                                    </div>


                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Banners", "HomeMs", new { p = ViewBag.pageNumber })">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {

}