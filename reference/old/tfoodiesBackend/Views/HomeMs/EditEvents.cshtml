@model Events

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>編輯活動花絮</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" enctype="multipart/form-data" action="@Url.Action("EditEvents", "HomeMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                        <div class="alert alert-danger alert-block">
                                            <h4 class="alert-heading">Error!</h4>
                                            @Html.ValidationSummary(true)
                                        </div>
                                }

                                @Html.HiddenFor(model => model.eventid)

                                <fieldset>

                                    <legend>活動花絮資料</legend>
                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="title">標題</label>
                                        <section class="col-lg-3">
                                            @Html.TextBoxFor(model => model.title, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入標題" } })
                                            @Html.ValidationMessageFor(model => model.title)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="summary">簡介</label>
                                        <section class="col-lg-5">
                                            @Html.TextAreaFor(model => model.summary, 3, 25, new Dictionary<string, object>() { { "class", "form-control" } })
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="intro">內文</label>
                                        <section class="col-lg-10">
                                            @Html.TextAreaFor(model => model.intro, 3, 60, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入內文" } })
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="photo">代表圖</label>
                                        <div class="col-lg-2">
                                            <p>
                                                <img src="@(ViewBag.BlobUrl + Model.photo)" width="auto" style="max-width:150px" />
                                            </p>
                                            <input type="file" class="btn btn-default" id="photo" name="photo"
                                                   data-bv-file="true"
                                                   data-bv-file-extension="jpeg,jpg,png,gif"
                                                   data-bv-file-type="image/jpeg,image/png,image/gif"
                                                   data-bv-file-message="代表圖格式不符">
                                            <p class="note">
                                                建議尺寸 : 397 x 296
                                            </p>
                                            @Html.ValidationMessageFor(model => model.photo)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="eventdate">活動時間</label>
                                        <section class="col-lg-2">
                                            @Html.TextBoxFor(model => model.eventdate, new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入活動日期" } })
                                            @Html.ValidationMessageFor(model => model.eventdate)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="shortener">短網址</label>
                                        <section class="col-lg-3">
                                            @Html.TextBoxFor(model => model.shortener, new Dictionary<string, object>() { { "class", "form-control" } })
                                            @Html.ValidationMessageFor(model => model.shortener)
                                        </section>
                                    </div>

                                </fieldset>

                                <fieldset>

                                    <legend>SEO資料</legend>
                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="keyword">關鍵字</label>
                                        <section class="col-lg-3">
                                            @Html.TextBoxFor(model => model.keyword, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入關鍵字" } })
                                            <p class="note">
                                                列三個關鍵字即可，不重複同樣的關鍵詞，需與文章內容相符
                                            </p>
                                            @Html.ValidationMessageFor(model => model.keyword)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="description">描述</label>
                                        <section class="col-lg-3">
                                            @Html.TextAreaFor(model => model.description, 3, 60, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入描述" } })
                                            <p class="note">
                                                字數控制在150字內，為文章內容大意，不得照摳文章內容來當敘述，盡量把關鍵字寫在敘述裡，不可以有引號
                                            </p>
                                            @Html.ValidationMessageFor(model => model.description)
                                        </section>
                                    </div>

                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Events", "HomeMs", new { p = ViewBag.pageNumber })">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {

}