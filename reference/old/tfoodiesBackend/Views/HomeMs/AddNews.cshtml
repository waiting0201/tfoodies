@model News

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>新增最新消息</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" enctype="multipart/form-data" action="@Url.Action("AddNews", "HomeMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                    <fieldset>

                                        <legend>最新消息資料</legend>
                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="title">標題</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.title, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入標題" } })
                                                @Html.ValidationMessageFor(model => model.title)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="summary">簡介</label>
                                            <section class="col-lg-5">
                                                @Html.TextAreaFor(model => model.summary, 3, 25, new Dictionary<string, object>() { { "class", "form-control" } })
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="photo">代表圖</label>
                                            <div class="col-lg-2">
                                                <input type="file" class="btn btn-default" id="photo" name="photo"
                                                       data-bv-notempty="true"
                                                       data-bv-notempty-message="請選擇代表圖"
                                                       data-bv-file="true"
                                                       data-bv-file-extension="jpeg,jpg,png,gif"
                                                       data-bv-file-type="image/jpeg,image/png,image/gif"
                                                       data-bv-file-message="代表圖格式不符">
                                                <p class="note">
                                                    建議尺寸 : 397 x 296
                                                </p>
                                                @Html.ValidationMessageFor(model => model.photo)
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="intro">介紹</label>
                                            <section class="col-lg-10">
                                                @Html.TextAreaFor(model => model.intro, 3, 60, new Dictionary<string, object>() { { "class", "form-control summernote" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入內文" } })
                                                <p class="note">
                                                    插入圖片時，要加入標題與圖片說明，並且需圖文相符，為自然文字敘述，不可為關鍵字堆疊。<br>
                                                    圖片也須正確命名，若遇到需要用空白鍵可用_代替。<br>
                                                    上傳圖片時須將較大的圖片壓縮再上傳。
                                                </p>
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="activitydate">活動時間</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.activitydate, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.activitydate)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="activityschedule">活動時程</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.activityschedule, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.activityschedule)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="publishdate">發佈日期</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.publishdate, new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入發佈日期" } })
                                                @Html.ValidationMessageFor(model => model.publishdate)
                                            </section>
                                        </div>

                                        <div class="form-group">
                                            <label class="col-lg-2 control-label" for="shortener">短網址</label>
                                            <section class="col-lg-3">
                                                @Html.TextBoxFor(model => model.shortener, new Dictionary<string, object>() { { "class", "form-control" } })
                                                @Html.ValidationMessageFor(model => model.shortener)
                                            </section>
                                        </div>

                                    </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("News", "HomeMs", new { p = ViewBag.pageNumber })">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {

}