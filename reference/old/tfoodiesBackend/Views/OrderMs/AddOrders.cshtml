        $("#addproduct").click(function () {
            var obj = $('.producttable tbody');
            var countRow = obj.find('tr').length;

            var row = '<tr>';
            row += '<td><input type="text" name="orderdetails[' + countRow + '].productnum" class="form-control productnum" /><input type="hidden" name="orderdetails[' + countRow + '].productid" value="" /><input type="hidden" name="orderdetails[' + countRow + '].isgift" class="isgift" value="0" /></td>';
            row += '<td></td>';
            row += '<td>';
            row += '<div class="input-group">';
            row += '<input type="text" name="orderdetails[' + countRow + '].qty" class="form-control text-center productqty" />';
            row += '<div class="input-group-btn">';
            row += '<a class="btn btn-primary" data-toggle="modal" data-target="#warehousestockModal">...</a>';
            row += '</div>';
            row += '</div>';
            row += '</td>';
            row += '<td>';
            row += '<div class="input-group">';
