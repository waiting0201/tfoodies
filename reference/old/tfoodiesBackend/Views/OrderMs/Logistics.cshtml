@{
    var data = (IEnumerable<Logistics>)ViewBag.Logistics;
}

<!-- MAIN CONTENT -->
<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">
        <!-- row -->
        <div class="row">
            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <div class="well padding-10">

                    <!-- widget content -->
                    <div class="widget-body">

                        @using (Html.BeginForm("SortLogistics", "OrderMs", FormMethod.Post, new { @id = "form" }))
                        {
                            <div class="widget-body-toolbar">

                                <div class="row">

                                    <div class="form-inline">
                                        <div class="col-sm-10">
                                            @*<button class="btn btn-info btn-labeled" type="submit"> <span class="btn-label"><i class="fa fa-refresh"></i></span>儲存排序</button>*@
                                            <a class="btn btn-success btn-labeled" href="@Url.Action("AddLogistics", "OrderMs")"> <span class="btn-label"><i class="fa fa-plus"></i></span>新增物流 </a>
                                        </div>
                                    </div>

                                </div>

                            </div>

                            if (Html.ValidationSummary(true) != null)
                            {
                                <div class="alert alert-danger alert-block fade in">
                                    <button class="close" data-dismiss="alert">
                                        ×
                                    </button>
                                    <i class="fa-fw fa fa-info"></i>
                                    @Html.ValidationSummary(true)
                                </div>
                            }

                            <div class="table-responsive">

                                <table class="table table-hover table-bordered table-striped smart-form">
                                    <thead>
                                        <tr>
                                            <th width="7%" class="text-center">編號</th>
                                            <th>標題</th>
                                            <th width="20%">地址</th>
                                            <th width="10%">電話</th>
                                            <th width="5%" class="text-center">狀態</th>
                                            <th width="5%" class="text-center">編輯</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (Logistics entity in data)
                                        {
                                            <tr>
                                                <th class="text-center">@entity.logisticcode</th>
                                                <td>@entity.title</td>
                                                <td>@entity.address</td>
                                                <td>@entity.phone</td>
                                                <td class="text-center">@(entity.isenable ? "開啟" : "關閉")</td>
                                                <td class="text-center"><a href="@Url.Action("EditLogistics", "OrderMs", new { logisticid = entity.logisticid })" class="btn btn-info btn-xs"><i class="fa fa-edit"></i></a></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                            </div>
                        }
                    </div>
                    <!-- end widget content -->

                </div>

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
<!-- END MAIN CONTENT -->
@section scripts {

}