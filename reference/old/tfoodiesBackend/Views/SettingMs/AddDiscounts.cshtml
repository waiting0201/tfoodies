@model Discounts

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>新增折扣碼</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" action="@Url.Action("AddDiscounts", "SettingMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                <fieldset>

                                    <legend>折扣碼資料</legend>
                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="discountcode">折扣碼</label>
                                        <section class="col-lg-2">
                                            @Html.TextBoxFor(model => model.discountcode, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入折扣碼" }, { "data-bv-remote", "true" }, { "data-bv-remote-url", Url.Action("Checkdiscountcode", "Ajax") }, { "data-bv-remote-message", "折扣碼重複" }, { "data-bv-remote-type", "GET" } })
                                            @Html.ValidationMessageFor(model => model.discountcode)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="istype">折扣類型</label>
                                        <section class="col-lg-3">
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.istype, 0, new { @checked = "checked" })
                                                折扣
                                            </label>
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.istype, 1)
                                                折價
                                            </label>
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="v">折扣</label>
                                        <section class="col-lg-2">
                                            @Html.TextBoxFor(model => model.v, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入折扣" } })
                                            @Html.ValidationMessageFor(model => model.v)
                                            <p>
                                                折扣類型為折扣時，85折請輸入0.85<br>
                                                折扣類型為折價時，請直接輸入金額
                                            </p>
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="startdate">開始日期</label>
                                        <section class="col-lg-2">
                                            @Html.TextBoxFor(model => model.startdate, new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" } })
                                            @Html.ValidationMessageFor(model => model.startdate)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="expiredate">截止日期</label>
                                        <section class="col-lg-2">
                                            @Html.TextBoxFor(model => model.expiredate, new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" } })
                                            @Html.ValidationMessageFor(model => model.expiredate)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="isonetime">限用設定</label>
                                        <section class="col-lg-3">
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.isonetime, 0, new { @checked = "checked" })
                                                無限
                                            </label>
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.isonetime, 1)
                                                限用一次
                                            </label>
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label">備註</label>
                                        <div class="col-lg-4">
                                            @Html.TextAreaFor(model => model.memo, 3, 40, new Dictionary<string, object>() { { "class", "form-control" } })
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="status">狀態</label>
                                        <div class="col-lg-3">
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.isdisable, 0, new { @checked = "checked" })
                                                啟用
                                            </label>
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.isdisable, 1)
                                                關閉
                                            </label>
                                        </div>
                                    </div>     

                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Discounts", "SettingMs", new { p = ViewBag.pageNumber })">
                                                返回
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {

}