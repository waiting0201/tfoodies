@{
    var datas = (IPagedList<Stocks>)ViewBag.Stocks;
}

<!-- MAIN CONTENT -->
<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">
        <!-- row -->
        <div class="row">
            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <div class="well padding-10">

                    <!-- widget content -->
                    <div class="widget-body">

                        <div class="widget-body-toolbar">

                            <div class="row">

                                <div class="form-inline">

                                    <div class="col-sm-10">
                                            
                                        <a class="btn btn-success btn-labeled" href="@Url.Action("AddStocks", "InventoryMs", new { p = ViewBag.pageNumber })"> <span class="btn-label"><i class="fa fa-plus"></i></span>新增需申報入庫 </a>
                                        <a class="btn btn-success btn-labeled" href="@Url.Action("AddNoStocks", "InventoryMs", new { p = ViewBag.pageNumber })"> <span class="btn-label"><i class="fa fa-plus"></i></span>新增不需申報入庫 </a>

                                    </div>

                                </div>

                            </div>

                        </div>

                        @if (Html.ValidationSummary(true) != null)
                        {
                            <div class="alert alert-danger alert-block fade in">
                                <button class="close" data-dismiss="alert">
                                    ×
                                </button>
                                <i class="fa-fw fa fa-info"></i>
                                @Html.ValidationSummary(true)
                            </div>
                        }

                        <div class="table-responsive">

                            <table class="table table-hover table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th width="6%" class="text-center">分類</th>
                                        <th width="6%" class="text-center">入庫日期</th>
                                        <td>產品名稱</td>
                                        <th width="10%">通知號碼</th>
                                        <th width="9%">報單號及項次</th>
                                        <th width="6%" class="text-center">入庫數量</th>
                                        <th width="6%" class="text-center">入庫淨重</th>
                                        <th width="6%" class="text-center">製造日期</th>
                                        <th width="6%" class="text-center">有效日期</th>
                                        <th width="5%" class="text-center">狀態</th>
                                        <th width="5%" class="text-center">編輯</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (Stocks entity in datas)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                @if (entity.stocktype == 1)
                                                {
                                                    <span class="label label-primary">需申報</span>
                                                }
                                                else
                                                {
                                                    <span class="label label-success">不需申報</span>
                                                }
                                            </td>
                                            <td class="text-center">@entity.createdate.ToString("yyyy-MM-dd")</td>
                                            <td>@entity.Purchasedetails.Products.title @entity.Purchasedetails.Products.capacity</td>
                                            @if (entity.stocktype == 1)
                                            {
                                            <td>@entity.noticenumber</td>
                                            <td>@entity.declarationnumber @entity.item</td>
                                            }
                                            else
                                            {
                                            <td colspan="2">-</td>
                                            }
                                            <td class="text-center">@entity.quantity</td>
                                            @if (entity.stocktype == 1)
                                            {
                                            <td class="text-center">@entity.weight</td>
                                            <td class="text-center">@Convert.ToDateTime(entity.manufacturedate).ToString("yyyy-MM-dd")</td>
                                            <td class="text-center">@Convert.ToDateTime(entity.expiredate).ToString("yyyy-MM-dd")</td>
                                            <td class="text-center">
                                                @if (entity.status == 1)
                                                {
                                                    <span class="label label-success">合格</span>
                                                }
                                                else if (entity.status == 2)
                                                {
                                                    <span class="label label-danger">待複檢</span>
                                                }
                                            </td>
                                            }
                                            else
                                            {
                                            <td colspan="4">-</td>
                                            }
                                            @if (entity.stocktype == 1)
                                            {
                                            <td class="text-center"><a href="@Url.Action("EditStocks", "InventoryMs", new { entityid = entity.stockid, p = ViewBag.pageNumber })" class="btn btn-info btn-xs"><i class="fa fa-edit"></i></a></td>
                                            }
                                            else
                                            {
                                            <td class="text-center"><a href="@Url.Action("EditNoStocks", "InventoryMs", new { entityid = entity.stockid, p = ViewBag.pageNumber })" class="btn btn-info btn-xs"><i class="fa fa-edit"></i></a></td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>

                        </div>
                        
                    </div>
                    <!-- end widget content -->

                    <div class="text-center">
                        @Html.PagedListPager(list: datas, generatePageUrl: page => Url.Action("Stocks", new { p = page }))
                    </div>

                </div>

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
<!-- END MAIN CONTENT -->
@section scripts {

}