@model Stocks
@{
    var purchasedatas = (IEnumerable<Purchases>)ViewBag.Purchases;
    var warehousedatas = (IEnumerable<Warehouses>)ViewBag.Warehouses;
}

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>新增需申報入庫</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" action="@Url.Action("AddStocks", "InventoryMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                <fieldset>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label">採購單</label>
                                        <div class="col-lg-6 form-inline">
                                            <select id="purchaseid" name="purchaseid" class="form-control selectpurchase" data-bv-notempty="true" data-bv-message="此為必填欄位">
                                                <option value="">請選擇採購單</option>
                                                @foreach (Purchases entity in purchasedatas)
                                                {
                                                    <option value="@entity.purchaseid">@entity.purchasecode</option>
                                                }
                                            </select>
                                            <select id="purchasedetailid" name="purchasedetailid" class="form-control selectpurchasedetail" data-bv-notempty="true" data-bv-message="此為必填欄位">
                                                <option value="">採購單細項</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="warehouseid">入庫倉</label>
                                        <div class="col-lg-2">
                                            <select id="warehouseid" name="warehouseid" class="form-control" data-bv-notempty="true" data-bv-message="此為必填欄位">
                                                <option value="">請選擇入庫倉</option>
                                                @foreach (Warehouses entity in warehousedatas)
                                                {
                                                    <option value="@entity.warehouseid">@entity.title</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="createdate">入庫日期</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.createdate, new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇入庫日期" } })
                                            @Html.ValidationMessageFor(model => model.createdate)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="barcode">條碼</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.barcode, new Dictionary<string, object>() { { "class", "form-control" } })
                                            @Html.ValidationMessageFor(model => model.barcode)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="noticenumber">通知號碼</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.noticenumber, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-remote", "true" }, { "data-bv-remote-url", Url.Action("Checknoticenumber", "Ajax") }, { "data-bv-remote-message", "許可通知號碼重複" }, { "data-bv-remote-type", "GET" } })
                                            @Html.ValidationMessageFor(model => model.noticenumber)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="declarationnumber">報單號</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.declarationnumber, new Dictionary<string, object>() { { "class", "form-control" } })
                                            @Html.ValidationMessageFor(model => model.declarationnumber)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="item">項次</label>
                                        <section class="col-lg-2">
                                            @Html.TextBoxFor(model => model.item, new Dictionary<string, object>() { { "class", "form-control" } })
                                            @Html.ValidationMessageFor(model => model.item)
                                        </section>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="manufacturedate">製造日期</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.manufacturedate, new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" } })
                                            @Html.ValidationMessageFor(model => model.manufacturedate)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="expiredate">到期日期</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.expiredate, new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇到期日期" } })
                                            @Html.ValidationMessageFor(model => model.expiredate)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="quantity">數量</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.quantity, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入數量" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                            @Html.ValidationMessageFor(model => model.quantity)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="weight">淨重</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.weight, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-numeric", "true" }, { "data-bv-numeric-message", "請輸入數字" } })
                                            @Html.ValidationMessageFor(model => model.weight)
                                        </div>
                                    </div>   
                                    
                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="status">狀態</label>
                                        <div class="col-lg-3">
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.status, 1, new { @checked = "checked" })
                                                合格
                                            </label>
                                            <label class="radio radio-inline">
                                                @Html.RadioButtonFor(model => model.status, 2)
                                                未合格，待複檢
                                            </label>
                                        </div>
                                    </div> 
                                    
                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="detailstatus">入庫狀態</label>
                                        <div class="col-lg-3">
                                            <label class="radio radio-inline">
                                                <input type="radio" name="detailstatus" value="1" checked>
                                                完整入庫
                                            </label>
                                            <label class="radio radio-inline">
                                                <input type="radio" name="detailstatus" value="2">
                                                有缺入庫
                                            </label>
                                            <label class="radio radio-inline">
                                                <input type="radio" name="detailstatus" value="3">
                                                有多入庫
                                            </label>
                                        </div>
                                    </div> 

                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Stocks", "InventoryMs", new { p = ViewBag.pageNumber })">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {
    <script>
        $(function () {
            $(".selectpurchase").change(function () {
                var obj = $(this);
                var parentobj = obj.parent().parent();
                var targetobj = parentobj.find(".selectpurchasedetail");
                $.post("@Url.Action("GetPurchaseDetailByPurchaseid", "Ajax")", {
                    'purchaseid': $(this).val()
                }, function (res) {
                    targetobj.find('option').remove().end().append(res);
                });
            });
        })
    </script>
}