@{
    var data = (IPagedList<Warehousestocks>)ViewBag.WarehouseStocks;
    IEnumerable<Warehouses> warehouses = (IEnumerable<Warehouses>)ViewBag.Warehouses;
    IEnumerable<Stocks> stocks = (IEnumerable<Stocks>)ViewBag.Stocks;
}

<!-- MAIN CONTENT -->
<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">
        <!-- row -->
        <div class="row">
            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <div class="well padding-10">

                    <!-- widget content -->
                    <div class="widget-body">

                        @using (Html.BeginForm("Warehousestocks", "InventoryMs", new { p = 1 }, FormMethod.Post, new { @id = "inventoryform" }))
                        {
                            <div class="widget-body-toolbar">

                                <div class="row">

                                    <div class="form-inline">

                                        <div class="col-sm-10">

                                            <select name="warehouseid" class="form-control">
                                                <option value="">請選擇倉儲</option>
                                                @foreach(Warehouses warehouse in warehouses)
                                                {
                                                    <option value="@warehouse.warehouseid" @(ViewBag.warehouseid == warehouse.warehouseid ? "selected" : "")>@warehouse.title</option>
                                                }
                                            </select>
                                            <select name="stockid" class="form-control">
                                                <option value="">請選擇產品名稱</option>
                                                @foreach (Stocks stock in stocks)
                                                {
                                                    <option value="@stock.stockid"@(ViewBag.stockid == stock.stockid ? "selected" : "")>@stock.noticenumber @stock.Purchasedetails.Products.title @stock.Purchasedetails.Products.capacity</option>
                                                }
                                            </select>
                                            <button class="btn btn-primary" type="submit">篩選</button>

                                        </div>

                                    </div>

                                </div>

                            </div>
                        }

                        @using (Html.BeginForm("SortWarehousestocks", "inventoryMs", new { p = ViewBag.pageNumber }, FormMethod.Post, new { @id = "form" }))
                        {
                            <div class="widget-body-toolbar">

                                <div class="row">

                                    <div class="form-inline">
                                        <div class="col-sm-10">
                                            @*<button class="btn btn-info btn-labeled" type="submit"> <span class="btn-label"><i class="fa fa-refresh"></i></span>儲存排序</button>*@
                                            <a class="btn btn-success btn-labeled" href="@Url.Action("AddWarehousestocks", "InventoryMs", new { p = ViewBag.pageNumber })"> <span class="btn-label"><i class="fa fa-plus"></i></span>新增移倉 </a>
                                        </div>
                                    </div>

                                </div>

                            </div>

                            if (Html.ValidationSummary(true) != null)
                            {
                                <div class="alert alert-danger alert-block fade in">
                                    <button class="close" data-dismiss="alert">
                                        ×
                                    </button>
                                    <i class="fa-fw fa fa-info"></i>
                                    @Html.ValidationSummary(true)
                                </div>
                            }

                            <div class="table-responsive">

                                <table class="table table-hover table-bordered table-striped smart-form">
                                    <thead>
                                        <tr>
                                            <th width="8%" class="text-center">移倉日期</th>
                                            <th width="12%" class="text-center">倉儲</th>
                                            <th width="12%" class="text-center">通知號碼</th>
                                            <th>產品名稱</th>
                                            <th width="7%" class="text-center">入庫數量</th>
                                            <th width="7%" class="text-center">剩餘數量</th>
                                            <th width="5%" class="text-center">列印</th>
                                            <th width="5%" class="text-center">編輯</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (Warehousestocks entity in data)
                                        {
                                            <tr>
                                                <td class="text-center">@entity.transdate.ToString("yyyy-MM-dd")</td>
                                                <td class="text-center">@entity.Warehouses.title</td>
                                                <td class="text-center">@entity.Stocks.noticenumber</td>
                                                <td>@entity.Stocks.Purchasedetails.Products.title @entity.Stocks.Purchasedetails.Products.capacity</td>
                                                <td class="text-center">@entity.quantity</td>
                                                <td class="text-center"><b>@entity.quantity_left</b></td>
                                                <td class="text-center"><a href="@Url.Action("PrintWarehousestocks", "InventoryMs", new { entityid = entity.warehousestockid })" class="btn btn-info btn-xs"><i class="fa fa-print"></i></a></td>
                                                <td class="text-center"><a href="@Url.Action("EditWarehousestocks", "InventoryMs", new { entityid = entity.warehousestockid, p = ViewBag.pageNumber })" class="btn btn-info btn-xs"><i class="fa fa-edit"></i></a></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                            </div>
                        }
                    </div>
                    <!-- end widget content -->

                    <div class="text-center">
                        @Html.PagedListPager(list: data, generatePageUrl: page => Url.Action("Warehousestocks", new { p = page, ViewBag.warehouseid, ViewBag.stockid }))
                    </div>

                </div>

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
<!-- END MAIN CONTENT -->
<!-- Modal -->
<div class="modal fade" id="confirm-delete" tabindex="-1" role="dialog" aria-labelledby="" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">
                    &times;
                </button>
                <h4 class="modal-title" id="myModalLabel">確認</h4>
            </div>
            <div class="modal-body">
                <p>
                    確定要刪除嗎？
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    取消
                </button>
                <a href="#" class="btn btn-primary btn-ok">
                    確定
                </a>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->
@section scripts {

}