@model Warehousestocks
@{
    var warehousedatas = (IEnumerable<Warehouses>)ViewBag.Warehouses;
}

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>編輯移倉</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" action="@Url.Action("EditWarehousestocks", "InventoryMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                @Html.HiddenFor(model => model.warehousestockid)

                                <fieldset>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="transdate">移倉日期</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.transdate, "{0:yyyy-MM-dd}", new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇移倉日期" }, { "disabled", "disabled" } })
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="stockid">產品</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.Stocks.Purchasedetails.Products.title, new Dictionary<string, object>() { { "class", "form-control" }, { "disabled", "disabled" } })
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="warehouseid">移入倉</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.Warehouses.title, new Dictionary<string, object>() { { "class", "form-control" }, { "disabled", "disabled" } })
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="quantity">入庫數量</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.quantity, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入數量" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                            @Html.ValidationMessageFor(model => model.quantity)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="quantity_left">剩餘數量</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.quantity_left, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入數量" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                            @Html.ValidationMessageFor(model => model.quantity_left)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="memo">備註</label>
                                        <div class="col-lg-3">
                                            @Html.TextAreaFor(model => model.memo, 2, 30, new Dictionary<string, object>() { { "class", "form-control" } })
                                        </div>
                                    </div>

                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Warehousestocks", "InventoryMs", new { p = ViewBag.pageNumber })">
                                                返回
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {

}