@model Stocks
@{
    var purchasedatas = (IEnumerable<Purchases>)ViewBag.Purchases;
}

<div id="content">

    <!-- widget grid -->
    <section id="widget-grid" class="">

        <!-- row -->
        <div class="row">

            <!-- NEW WIDGET START -->
            <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">

                <!-- Widget ID (each widget will need unique ID)-->
                <div class="jarviswidget" id="wid-id-4" data-widget-editbutton="false" data-widget-colorbutton="false" data-widget-togglebutton="false" data-widget-deletebutton="false" data-widget-fullscreenbutton="false" data-widget-custombutton="false" data-widget-collapsed="false" data-widget-sortable="false">
                    <header>
                        <span class="widget-icon"> <i class="fa fa-pencil-square-o"></i> </span>
                        <h2>編輯不需申報入庫</h2>

                    </header>

                    <!-- widget div-->
                    <div>

                        <!-- widget edit box -->
                        <div class="jarviswidget-editbox">
                            <!-- This area used as dropdown edit box -->

                        </div>
                        <!-- end widget edit box -->
                        <!-- widget content -->
                        <div class="widget-body">

                            <form id="form" method="post" class="form-horizontal" action="@Url.Action("EditNoStocks", "InventoryMs", new { p = ViewBag.pageNumber })"
                                  data-bv-message="This value is not valid"
                                  data-bv-feedbackicons-valid="glyphicon glyphicon-ok"
                                  data-bv-feedbackicons-invalid="glyphicon glyphicon-remove"
                                  data-bv-feedbackicons-validating="glyphicon glyphicon-refresh">

                                @if (Html.ValidationSummary(true) != null)
                                {
                                    <div class="alert alert-danger alert-block">
                                        <h4 class="alert-heading">Error!</h4>
                                        @Html.ValidationSummary(true)
                                    </div>
                                }

                                @Html.HiddenFor(model => model.stockid)

                                <fieldset>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label">採購單</label>
                                        <div class="col-lg-6 form-inline">
                                            <input type="text" class="form-control" value="@Model.Purchasedetails.Purchases.purchasecode" disabled />
                                            <input type="text" class="form-control" style="width:200px" value="@Model.Purchasedetails.Products.title" disabled />
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="createdate">入庫日期</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.createdate, "{0:yyyy-MM-dd}", new Dictionary<string, object>() { { "class", "form-control datepicker" }, { "data-dateformat", "yy-mm-dd" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請選擇入庫日期" } })
                                            @Html.ValidationMessageFor(model => model.createdate)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="quantity">數量</label>
                                        <div class="col-lg-2">
                                            @Html.TextBoxFor(model => model.quantity, new Dictionary<string, object>() { { "class", "form-control" }, { "data-bv-notempty", "true" }, { "data-bv-message", "請輸入數量" }, { "data-bv-integer", "true" }, { "data-bv-integer-message", "請輸入數字" } })
                                            @Html.ValidationMessageFor(model => model.quantity)
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-lg-2 control-label" for="detailstatus">入庫狀態</label>
                                        <div class="col-lg-3">
                                            <label class="radio radio-inline">
                                                <input type="radio" name="detailstatus" value="1" @(Model.Purchasedetails.status == 1 ? "checked" : "")>
                                                完整入庫
                                            </label>
                                            <label class="radio radio-inline">
                                                <input type="radio" name="detailstatus" value="2" @(Model.Purchasedetails.status == 2 ? "checked" : "")>
                                                有缺入庫
                                            </label>
                                            <label class="radio radio-inline">
                                                <input type="radio" name="detailstatus" value="3" @(Model.Purchasedetails.status == 3 ? "checked" : "")>
                                                有多入庫
                                            </label>
                                        </div>
                                    </div>

                                </fieldset>

                                <div class="form-actions">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-default" href="@Url.Action("Stocks", "InventoryMs", new { p = ViewBag.pageNumber })">
                                                取消
                                            </a>
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fa fa-save"></i>
                                                確認
                                            </button>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                        <!-- end widget content -->

                    </div>
                    <!-- end widget div -->

                </div>
                <!-- end widget -->

            </article>
            <!-- WIDGET END -->

        </div>
        <!-- end row -->

    </section>
    <!-- end widget grid -->

</div>
@section scripts {
    <script>
        $(function () {

        })
    </script>
}