
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>T Foodies</title>
    <meta name="KeyWords" content="">
    <meta name="Description" content="">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <style>
        body {
            background-color: #26b7bc;
        }

        .content-wrap {
            display: flex;
            height: 100vh;
            align-items: center;
            justify-content: center;
        }

        .soon-inner {
            width: 100%;
        }

        .soon-logo {
            padding-bottom: 1em;
        }

        .soon-title img {
            border-top: 1px solid white;
            padding: 1em 0;
        }

        img {
            display: block;
            max-width: 100%;
            margin: auto;
        }

        #timer {
            font-size: 38px;
            font-family: 'Arial', sans-serif;
            color: white;
        }

        .countdown-row {
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .countdown-section {
            display: block;
            padding: 0 .4em;
        }

        .countdown-period {
            font-size: 16px;
            display: block;
        }

        @@media screen and (min-width: 375px) {
            #timer {
                font-size: 48px;
            }
        }

        @@media screen and (min-width: 400px) {
            #timer {
                font-size: 58px;
            }
        }

        @@media screen and (min-width: 768px) {
            #timer {
                font-size: 84px;
            }
        }

        @@media screen and (min-width: 1024px) {
            #timer {
                font-size: 96px;
            }
        }
    </style>
</head>
<body id="comming-soon">
    <div class="content-wrap">
        <div class="soon-inner">
            <div class="pattern">
                <img src="~/content/images/common/pattern-10.png">
            </div>
            <div class="soon-logo">
                <img src="~/content/images/common/logo.png">
            </div>
            <div class="soon-title">
                <img src="~/content/images/common/comming-title.png">
            </div>
            <div id="timer"></div>
        </div>
    </div>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/2.2.4/jquery.min.js"></script>
    <script src="~/scripts/countdown/jquery.plugin.min.js"></script>
    <script src="~/scripts/countdown/jquery.countdown.min.js"></script>
    <script src="~/scripts/countdown/jquery.countdown-zh-TW.js"></script>
    <script>
            (function (i, s, o, g, r, a, m) {
                i['GoogleAnalyticsObject'] = r; i[r] = i[r] || function () {
                    (i[r].q = i[r].q || []).push(arguments)
                }, i[r].l = 1 * new Date(); a = s.createElement(o),
                m = s.getElementsByTagName(o)[0]; a.async = 1; a.src = g; m.parentNode.insertBefore(a, m)
            })(window, document, 'script', 'https://www.google-analytics.com/analytics.js', 'ga');

            ga('create', 'UA-88479607-1', 'auto');
            ga('send', 'pageview');

			$(function () {
				var austDay = new Date();
			    austDay = new Date(austDay.getFullYear() + 1, 0 - 1, 21, 11);
				//austDay = new Date(austDay.getFullYear() + 1, 0 - 1, 19, 11, 38);
				console.log(austDay)
				$('#timer').countdown({until: austDay, expiryUrl: 'http://www.tfoodies.com'}, $.countdown.regionalOptions['fr']);
				//$('#year').text(austDay.getFullYear());
			});
    </script>
</body>
</html>