@model Recipes
@{
    int step = 1;
}

<main id="main">
    <section class="restrict-wide allpadding">
        <div class="locate">
            <p>
                <a href="@Url.Action("Recipes", "MainMs", new { p = ViewBag.pageNumber })" class="descript">美味料理/</a><a href="javascript:;" class="descript main">@Model.title</a>
            </p>
        </div>
    </section>
    <section class="allpadding clr section">
        <div class="restrict-wide">
            <div class="recipe-wrap">
                <div class="food">
                    <div class="recipe-img"><img src="@(ViewBag.BlobUrl + Model.photo)" alt="@Model.title, 橄欖油"></div>
                </div>
                <div class="food-desc">
                    <h1>@Model.title</h1>
                    <div class="cook-desc-wrap clr">
                        <div class="cook-desc">
                            <div class="clock inline"></div>
                            <p>@Model.duration 分鐘</p>
                        </div>
                        <div class="cook-desc">
                            <div class="pnumber inline"></div>
                            <p>@Model.portion 人份</p>
                        </div>
                        @if (Model.youtube != null && Model.youtube != "")
                        {
                            <div class="cook-desc">
                                <a href="javascript:;" class="play inline"></a>
                                <p><a href="@Model.youtube" target="_blank">線上影片</a></p>
                            </div>
                        }
                    </div>
                    <div class="share centered">
                        <a href="" target="_blank"><img src="~/Content/images/common/cookpad.png"></a>
                        @Html.Partial("_Addthis", new ViewDataDictionary { { "url", Model.shortener }, { "title", Model.title } })
                    </div>
                    <div class="horizon-line"></div>
                    <p>@(Model.intro != null ? Html.Raw(Model.intro.Replace("\n", "<br />")) : Html.Raw(Model.intro))</p>
                </div>
            </div>
            <div class="horizon-line"></div>
            <section>
                <div class="ingredient-wrapper">
                    <div class="ingredient-box">
                        <table class="ingredient-table">
                            <tr>
                                <th>
                                    <h2 class="left">食材準備</h2>
                                </th>
                                <th></th>
                            </tr>
                            @foreach (Recipeingredients recipeingredient in Model.Recipeingredients.OrderBy(a => a.sort))
                            {
                                <tr>
                                    <td class="left">@recipeingredient.title</td>
                                    <td>@recipeingredient.value</td>
                                </tr>
                            }
                        </table>
                    </div>
                    <div class="ingredient-box">
                        <table class="ingredient-table">
                            <tr>
                                <th>
                                    <h2 class="left">調味料準備</h2>
                                </th>
                                <th></th>
                            </tr>
                            @*<tr>
                                    <td class="left"><a href="javascript:;" class="main">La barre特級冷壓初榨橄欖油</a></td>
                                    <td><a href="javascript:;" class="main">60 cc</a></td>
                                </tr>*@
                            @foreach (Recipeseasonings recipeseasoning in Model.Recipeseasonings.OrderBy(a => a.sort))
                            {
                                <tr>
                                    <td class="left">@recipeseasoning.title</td>
                                    <td>@recipeseasoning.value</td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>
            </section>
            <section class="allsection">
                <div class="step">
                    <h3>製作步驟</h3>
                    <article>
                        <ul>
                            @foreach (Recipesteps recipestep in Model.Recipesteps.OrderBy(a => a.sort))
                            {
                                <li class="steptitle">@step.@recipestep.title</li>
                                <li class="stepcontent">@(recipestep.value != null ? Html.Raw(recipestep.value.Replace("\n", "<br/>")) : Html.Raw(recipestep.value))</li>
                                step++;
                            }
                        </ul>
                    </article>
                </div>
            </section>
            <div class="centered more"><a href="@Url.Action("Recipes", "MainMs", new { p = ViewBag.pageNumber })" class="outline-btn">返回</a></div>
        </div>
    </section>
    @if (Model.Products.Count() > 0)
    {
    <section class="gray-bg allsection">
        <div class="restrict-wide allpadding">
            <div class="adstitle">
                <h2 class="main">購買相關商品</h2>
            </div>
            <div class="responsive promoteSlider clr">
                @foreach (Products product in Model.Products.Where(a => a.isdisabled == false).OrderByDescending(o => o.sort))
                {
                    @Html.Partial("_PartialProduct", product, new ViewDataDictionary { { "promote-sliding", true }, { "bloburl", ViewBag.BlobUrl } })
                }
            </div>
        </div>
    </section>
    }
</main>