@{
    var knowledgedatas = (IPagedList<Knowledges>)ViewBag.Knowledges;
}

<main id="main">
    <section class="gray-bg searchsection">
        <div class="restrict allpadding">
            <div class="search-column recipe-search">
                @*<div class="language-wrap">
                        <div class="slide-select">
                            <div class="slidedown-search">找美味料理</div>
                            <div class="slidecontent-search"><a href="javascript:;">找美味料理</a><a href="javascript:;">找健康生活</a></div>
                        </div>
                    </div>*@
                <div class="searchall recipe-input">
                    <form id="searchform" method="get" action="@Url.Action("Knowledges", "MainMs", new { p = ViewBag.pageNumber })">
                        <div class="controlgroup"><label for="searchall"></label><input type="text" name="k" placeholder="搜尋小知識" id="recipe-input" class="recipe-input"></div>
                        <a href="javascript:;" class="search-icon"></a>
                    </form>
                </div>
            </div>
        </div>
    </section>
    <section class="allpadding clr section">
        @*<div class="restrict-wide allpadding">
                <div class="clr">
                    <div class="pull-left">
                        <a class="back" href="@Url.Action("GreenIssues", "MainMs")">
                            <div class="inline">&#60;</div>
                            <div class="inline">返回綠誌</div>
                        </a>
                    </div>
                </div>
            </div>*@
        <div class="restrict-wide">
            <div class="centered">
                <h1>小知識</h1>
                <p class="restrict-small">解決你對橄欖油的各種疑問</p>
            </div>
            <div class="direct-line"></div>
            <div class="three-column clr">
                @foreach (Knowledges knowledge in knowledgedatas)
                {
                    <a href="@Url.Action("KnowledgeDetail", "MainMs", new { knowledgeid = knowledge.knowledgeid, p = ViewBag.pageNumber })" class="blog-wrap">
                        <div class="article-single centered">
                            <div class="article-pic"><img src="@(ViewBag.BlobUrl + knowledge.photo)" alt="@knowledge.question"></div>
                            <div class="article-title">@knowledge.question</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
    <div class="centered more">
        @Html.PagedListPager(list: knowledgedatas, generatePageUrl: page => Url.Action("Knowledges", new { p = page }))
    </div>
</main>
@section scripts {
    <script>
        $(function () {
            $(".recipe-input").keypress(function (e) {
                var code = (e.keyCode ? e.keyCode : e.which);
                if (code == 13) {
                    $(".search-icon").trigger("click");
                }
            });

            $(".search-icon").on('click', function () {
                var k = $("#recipe-input").val();

                if (k != "") {
                    $("#searchform").submit();
                }
            });
        });
    </script>
}
