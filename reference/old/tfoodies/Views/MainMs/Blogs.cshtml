@{
    var blogdatas = (IEnumerable<Blogs>)ViewBag.Blogs;
    int c = 0;
}

<main id="main">
    <section class="allpadding clr tallsection">
        @*<div class="restrict-wide allpadding">
            <div class="clr">
                <div class="pull-left">
                    <a class="back" href="@Url.Action("GreenIssues", "MainMs")">
                        <div class="inline">&#60;</div>
                        <div class="inline">返回綠誌</div>
                    </a>
                </div>
            </div>
        </div>*@
        <div class="restrict-wide">
            <div class="centered">
                <h1>部落客分享</h1>
            </div>
            <div class="direct-line"> </div>
        </div>
    </section>
    <section class="allpadding">
        <div class="restrict-wide">
            <div class="three-column clr page">
                @foreach (Blogs entity in blogdatas)
                {
                    if (c != 0 && c % 3 == 0) { @Html.Raw("</div><div class=\"three-column clr page\">") }
                <div class="blog-wrap">
                    <a href="@entity.link" class="article-single centered" target="_blank" rel="nofollow">
                        <div class="article-pic">
                            <img src="@(ViewBag.BlobUrl + entity.photo)">
                            <div class="blog-link">
                                <div class="blog-link-inner">
                                    <div class="share-link"></div>
                                </div>
                            </div>
                        </div>
                        <div class="article-title">@entity.title</div>
                    </a>
                </div>
                    c++;
                }
            </div>
        </div>
    </section>
    @*<div class="centered more">
        @Html.PagedListPager(list: blogdatas, generatePageUrl: page => Url.Action("Blogs", new { p = page }))
    </div>*@
    <div class="centered more"><a href="#wrapper" class="outline-btn">TOP</a></div>
</main>